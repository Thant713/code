{
  "edit_predictions": {
    "provider": "ollama",
    "mode": "subtle"
  },
  "theme": {
    "mode": "dark",
    "light": "One Dark",
    "dark": "One Dark"
  },
  "on_last_window_closed": "quit_app",
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
  },
  "icon_theme": "Warm Charmed Icons",
  "title_bar": {
    "show_onboarding_banner": true,
    "show_project_items": false,
    "show_branch_name": false,
    "show_user_menu": true,
  },
  "tab_bar": {
    "show": true,
  },
  "toolbar": {
    "quick_actions": true,
  },
  "status_bar": {
    "experimental.show": true,
  },
  "project_panel": {
    "dock": "right",
    "default_width": 400,
    "auto_fold_dirs": false,
    "starts_open": false,
    "git_status": true,
    "sticky_scroll": false,
    "scrollbar": {
      "show": "never",
    },
    "indent_guides": {
      "show": "never",
    },
  },
  "outline_panel": {
    "default_width": 300,
    "indent_guides": {
      "show": "always",
    },
  },
  "file_finder": {
    "modal_max_width": "large",
  },
  "scrollbar": {
    "show": "never",
  },
  "gutter": {
    "min_line_number_digits": 0,
    "folds": true,
    "runnables": true,
  },
  "indent_guides": {
    "enabled": true,
  },
  "ui_font_family": "Ubuntu Mono",
  "ui_font_size": 20,
  "buffer_font_family": "Ubuntu Mono",
  "buffer_font_size": 20,
  "buffer_line_height": {
    "custom": 2,
  },
  "agent_buffer_font_size": 20,
  "vim_mode": false,
  "multi_cursor_modifier": "cmd_or_ctrl",
  "cursor_shape": "bar",
  "cursor_blink": false,
  "selection_highlight": true,
  "drag_and_drop_selection": {
    "enabled": true,
  },
  "seed_search_query_from_cursor": "never",
  "current_line_highlight": "line",
  "show_whitespaces": "none",
  "tab_size": 2,
  "auto_indent": "syntax_aware",
  "auto_indent_on_paste": true,
  "show_completions_on_input": true,
  "show_completion_documentation": true,
  "inline_code_actions": true,
  "hover_popover_enabled": true,
  "format_on_save": "on",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000,
    },
  },
  "auto_update": false,
  "extend_comment_on_newline": true,
  "horizontal_scroll_margin": 1,
  "vertical_scroll_margin": 1,
  "when_closing_with_no_tabs": "close_window",
  "close_on_file_delete": true,
  "restore_on_file_reopen": false,
  "restore_on_startup": "last_session",
  "session": {
    "restore_unsaved_buffers": false,
  },
  "git": {
    "inline_blame": {
      "enabled": true,
    },
  },
  "centered_layout": {
    "right_padding": 0.15,
    "left_padding": 0.15,
  },
}
